# ==============================
# BASE DE DATOS
# ==============================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=servicio-tecnico
DB_PORT=3306

# ==============================
# SEGURIDAD
# ==============================
API_RATE_LIMIT=100
ENCRYPTION_KEY=TU_CLAVE_SECRETA_AQUI

# ==============================
# EMAIL (SMTP)
# ==============================
APP_EMAIL_MAILER=smtp
APP_EMAIL_HOST=tu_servidor_smtp
APP_EMAIL_PORT=465
APP_EMAIL_USER=tu_email@dominio.com
APP_EMAIL_PASSWORD=tu_password_smtp
APP_EMAIL_SECURE=ssl
APP_EMAIL=tu_email@dominio.com
APP_ALERTS_EMAIL=tu_email@dominio.com

# ==============================
# INFORMACIÓN DE LA APLICACIÓN
# ==============================
APP_THEME=default
APP_TITLE="Servicio Técnico"
APP_DESCRIPTION="Sistema administrativo"
APP_ABOUT="Descripción de tu empresa"

APP_OWNER_NAME="Tu Empresa"
APP_OWNER_ADDRESS="Tu Dirección"
APP_OWNER_URL=https://tu-sitio.com
APP_OWNER_EMAIL=soporte@tu-sitio.com
APP_OWNER_PHONE=+503-0000-0000

# ==============================
# TWILIO (2FA - opcional)
# ==============================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_ID=
TWILIO_2FA_SERVICE_ID=

# ==============================
# GOOGLE (opcional)
# ==============================
GOOGLE_API_KEY=
GOOGLE_ANALYTICS_ID=

# ==============================
# OAUTH FACEBOOK (opcional)
# ==============================
OAUTH_FACEBOOK_ID=
OAUTH_FACEBOOK_SECRET=

# ==============================
# OAUTH GOOGLE (opcional)
# ==============================
OAUTH_GOOGLE_ID=
OAUTH_GOOGLE_SECRET=

# ==============================
# SESIONES Y COOKIES
# ==============================
AUTH_COOKIE_NAME=sa_a
AUTH_TOKEN_SESSION_NAME=sa_st
CSRF_SESSION_NAME=SA::CSRF
OAUTH_PROVIDER_SESSION_NAME=SA::OAUTH-PROVIDER

# ==============================
# ENTORNO: dev | test | prod
# ==============================
ENVIRONMENT=dev
LOCAL_DEV=true
